From 57ff9034b5e551fae959dfc26898f14a67a97e14 Mon Sep 17 00:00:00 2001
From: Codex <codex@openai.com>
Date: Tue, 21 Jul 2026 12:31:37 +0900
Subject: [PATCH] Handle reversed NSD HDF5 spatial axes

---
 notebooks/01_data_orientation.ipynb |  2 +-
 nsdimagery/io.py                    | 29 +++++++++++++++++++++--------
 2 files changed, 22 insertions(+), 9 deletions(-)

diff --git a/notebooks/01_data_orientation.ipynb b/notebooks/01_data_orientation.ipynb
index 3303b01..5ccc909 100644
--- a/notebooks/01_data_orientation.ipynb
+++ b/notebooks/01_data_orientation.ipynb
@@ -1588,7 +1588,7 @@
    "source": [
     "## 6. HDF5 beta file: shape, chunks, and units\n",
     "\n",
-    "The manual describes `/betas` in MATLAB order as `X × Y × Z × 720`. Because these files were written from MATLAB, **h5py normally exposes the same data as `720 × X × Y × Z`**. The code detects the layout rather than assuming an axis. Values are stored as `int16` after multiplying percent signal change by 300. Correct loading casts to floating point and divides by 300. The chunking is optimized for reading all events from a small number of voxels."
+    "The manual describes `/betas` in MATLAB order as `X × Y × Z × 720`. Because these files were written from MATLAB, **h5py exposes this release as `720 × Z × Y × X`**. For example, subject 1 has beta shape `(720, 83, 104, 81)` but NIfTI mask shape `(81, 104, 83)`. Thus a NIfTI coordinate `(x, y, z)` indexes HDF5 as `betas[:, z, y, x]`. The code detects this layout rather than assuming axes. Values are stored as `int16` after multiplying percent signal change by 300; correct loading casts to floating point and divides by 300."
    ]
   },
   {
diff --git a/nsdimagery/io.py b/nsdimagery/io.py
index c2a09c9..cff6992 100644
--- a/nsdimagery/io.py
+++ b/nsdimagery/io.py
@@ -191,15 +191,22 @@ def infer_beta_layout(
     """Identify how Python exposes the MATLAB-written NSD HDF5 dimensions.
 
     The NSD manual uses MATLAB order ``X × Y × Z × events``. In the released
-    files, h5py commonly exposes the reversed HDF5 dimension convention as
-    ``events × X × Y × Z``. Supporting both prevents a silent axis mistake.
+    files, h5py commonly exposes the fully reversed HDF5 dimension convention
+    as ``events × Z × Y × X``. Supporting all plausible layouts prevents a
+    silent spatial-axis mistake.
     """
     dataset_shape = tuple(dataset_shape)
     spatial_shape = tuple(spatial_shape)
-    if dataset_shape[0] == 720 and dataset_shape[1:] == spatial_shape:
-        return "events_first"
-    if dataset_shape[-1] == 720 and dataset_shape[:-1] == spatial_shape:
-        return "events_last"
+    if dataset_shape[0] == 720:
+        if dataset_shape[1:] == spatial_shape:
+            return "events_first_xyz"
+        if dataset_shape[1:] == spatial_shape[::-1]:
+            return "events_first_zyx"
+    if dataset_shape[-1] == 720:
+        if dataset_shape[:-1] == spatial_shape:
+            return "events_last_xyz"
+        if dataset_shape[:-1] == spatial_shape[::-1]:
+            return "events_last_zyx"
     raise ValueError(
         f"Cannot reconcile beta shape {dataset_shape} with ROI shape {spatial_shape} "
         "and 720 expected events"
@@ -257,12 +264,18 @@ def extract_masked_betas(
         dataset = handle["betas"]
         layout = infer_beta_layout(dataset.shape, mask.shape)
         values = np.empty((720, len(coordinates)), dtype=np.float32)
-        if layout == "events_first":
+        if layout == "events_first_xyz":
             for column, (x, y, z) in enumerate(coordinates):
                 values[:, column] = dataset[:, x, y, z]
-        else:
+        elif layout == "events_first_zyx":
+            for column, (x, y, z) in enumerate(coordinates):
+                values[:, column] = dataset[:, z, y, x]
+        elif layout == "events_last_xyz":
             for column, (x, y, z) in enumerate(coordinates):
                 values[:, column] = dataset[x, y, z, :]
+        else:  # events_last_zyx
+            for column, (x, y, z) in enumerate(coordinates):
+                values[:, column] = dataset[z, y, x, :]
 
     # NSD stores these int16 values after multiplying percent signal change by 300.
     values /= 300.0
-- 
2.51.1

