+            train_norm[:, None] + train_norm[None, :] - 2 * x_train @ x_train.T
+        )
+        test_distance = (
+            test_norm[:, None] + train_norm[None, :] - 2 * x_test @ x_train.T
+        )
+        np.maximum(train_distance, 0, out=train_distance)
